# Splitwise API Credentials
# Get these from: https://secure.splitwise.com/apps

# Consumer Key (from your app registration)
SPLITWISE_CONSUMER_KEY=your_consumer_key_here

# Consumer Secret (from your app registration)
SPLITWISE_CONSUMER_SECRET=your_consumer_secret_here

# OAuth Access Token (obtained after authorization)
SPLITWISE_ACCESS_TOKEN=your_access_token_here
SPLITWISE_ACCESS_SECRET=your_access_token_secret_here

# Default currency (optional, defaults to INR)
DEFAULT_CURRENCY=INR
