SCRIPTS_DIR = BASE_DIR / 'scripts'

# Add scripts to path
sys.path.insert(0, str(SCRIPTS_DIR))

# Also load .env file
from dotenv import load_dotenv
load_dotenv(BASE_DIR / '.env')

